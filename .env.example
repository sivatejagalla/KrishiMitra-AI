PROJECT_NAME="Agrolith AI Production Backend"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY="change-this-to-a-32-char-random-secret"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS="serviceAccountKey.json"

# ─── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"

# ─── Weather (Open-Meteo is free, no key needed) ───────────────────────────────
OPENWEATHER_API_KEY=""

# ─── Language & Localisation ───────────────────────────────────────────────────
DEFAULT_LANGUAGE="en"
SUPPORTED_LANGUAGES=["en","hi","te","ta","mr"]

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="sqlite:///./agrolith.db"

# ─── CORS ──────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["*"]

# ─── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
WHATSAPP_TOKEN="your-permanent-system-user-access-token"
PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
VERIFY_TOKEN="agrolith_whatsapp_verify_token_2026"
